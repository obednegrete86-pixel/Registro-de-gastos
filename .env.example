# Copia este archivo a backend/.env y frontend/.env según indique el README.

# --- Backend (backend/.env) ---
PORT=4000
NODE_ENV=development

# URL del frontend (en producción: https://tu-app.onrender.com o la URL que uses)
FRONTEND_URL=http://localhost:5173

# PostgreSQL (Render te da DATABASE_URL al crear la base)
DATABASE_URL=postgresql://usuario:clave@localhost:5432/registro_gastos

# Secreto para firmar la cookie de sesión (cadena larga aleatoria en producción)
SESSION_SECRET=cambia-esto-por-algo-largo-y-aleatorio

# Contraseñas de acceso (mismas cuentas: Obed y Lupita)
AUTH_OBED_PASSWORD=
AUTH_LUPITA_PASSWORD=

# --- Frontend (frontend/.env) ---
# En desarrollo suele quedar vacío (Vite hace proxy a /api).
# En producción, si el API está en otro dominio, pon la URL base del API:
# VITE_API_BASE=https://tu-api.onrender.com
